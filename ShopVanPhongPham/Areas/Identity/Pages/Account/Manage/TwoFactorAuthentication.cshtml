@page
@using Microsoft.AspNetCore.Http.Features
@model TwoFactorAuthenticationModel
@{
    ViewData["Title"] = "Xác thực hai bước (2FA)";
    ViewData["ActivePage"] = ManageNavPages.TwoFactorAuthentication;
}

<partial name="_StatusMessage" for="StatusMessage" />

<div class="card shadow-sm">
    <div class="card-body p-4">
        <h5 class="card-title mb-4">
            <i class="bi bi-shield-lock me-2"></i>Xác thực hai bước (2FA)
        </h5>

        @{
            var consentFeature = HttpContext.Features.Get<ITrackingConsentFeature>();
            @if (consentFeature?.CanTrack ?? true)
            {
                @if (Model.Is2faEnabled)
                {
                    if (Model.RecoveryCodesLeft == 0)
                    {
                        <div class="alert alert-danger">
                            <i class="bi bi-exclamation-octagon me-2"></i>
                            <strong>Bạn đã dùng hết mã khôi phục.</strong>
                            <p class="mb-0 mt-1">
                                Vui lòng
                                <a asp-page="./GenerateRecoveryCodes">tạo bộ mã khôi phục mới</a>
                                trước khi đăng nhập bằng mã khôi phục.
                            </p>
                        </div>
                    }
                    else if (Model.RecoveryCodesLeft == 1)
                    {
                        <div class="alert alert-danger">
                            <i class="bi bi-exclamation-octagon me-2"></i>
                            <strong>Bạn chỉ còn 1 mã khôi phục.</strong>
                            <p class="mb-0 mt-1">
                                Bạn nên
                                <a asp-page="./GenerateRecoveryCodes">tạo bộ mã khôi phục mới</a>.
                            </p>
                        </div>
                    }
                    else if (Model.RecoveryCodesLeft <= 3)
                    {
                        <div class="alert alert-warning">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            <strong>Bạn còn @Model.RecoveryCodesLeft mã khôi phục.</strong>
                            <p class="mb-0 mt-1">
                                Bạn nên
                                <a asp-page="./GenerateRecoveryCodes">tạo bộ mã khôi phục mới</a>.
                            </p>
                        </div>
                    }

                    <div class="d-flex flex-wrap gap-2 mb-4">
                        @if (Model.IsMachineRemembered)
                        {
                            <form method="post" style="display:inline">
                                <button type="submit" class="btn btn-outline-secondary">
                                    <i class="bi bi-browser-chrome me-1"></i>Quên trình duyệt này
                                </button>
                            </form>
                        }
                        <a asp-page="./Disable2fa" class="btn btn-outline-danger">
                            <i class="bi bi-shield-x me-1"></i>Tắt xác thực 2 bước
                        </a>
                        <a asp-page="./GenerateRecoveryCodes" class="btn btn-outline-warning">
                            <i class="bi bi-arrow-clockwise me-1"></i>Đặt lại mã khôi phục
                        </a>
                    </div>
                }

                <h6 class="fw-semibold mb-3">
                    <i class="bi bi-phone me-2"></i>Ứng dụng xác thực
                </h6>
                <div class="d-flex flex-wrap gap-2">
                    @if (!Model.HasAuthenticator)
                    {
                        <a id="enable-authenticator" asp-page="./EnableAuthenticator"
                           class="btn btn-primary">
                            <i class="bi bi-plus-circle me-1"></i>Thêm ứng dụng xác thực
                        </a>
                    }
                    else
                    {
                        <a id="enable-authenticator" asp-page="./EnableAuthenticator"
                           class="btn btn-primary">
                            <i class="bi bi-gear me-1"></i>Cài đặt ứng dụng xác thực
                        </a>
                        <a id="reset-authenticator" asp-page="./ResetAuthenticator"
                           class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-repeat me-1"></i>Đặt lại ứng dụng xác thực
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-danger">
                    <i class="bi bi-x-circle me-2"></i>
                    <strong>Chính sách bảo mật và cookie chưa được chấp nhận.</strong>
                    <p class="mb-0 mt-1">Bạn cần chấp nhận chính sách trước khi bật xác thực hai bước.</p>
                </div>
            }
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}