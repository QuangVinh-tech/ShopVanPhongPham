@page
@model DeletePersonalDataModel
@{
    ViewData["Title"] = "Xóa tài khoản";
    ViewData["ActivePage"] = ManageNavPages.PersonalData;
}

<div class="card shadow-sm">
    <div class="card-body p-4">
        <h5 class="card-title mb-4"><i class="bi bi-trash me-2"></i>@ViewData["Title"]</h5>

        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="alert alert-danger">
            <strong>Xóa dữ liệu tài khoản này sẽ xóa vĩnh viễn và không thể khôi phục.</strong>
        </div>

        <form method="post">
            @if (Model.RequirePassword)
            {
                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" />
                    <label asp-for="Input.Password">Mật khẩu</label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>
            }
            <button class="btn btn-danger" type="submit">Xóa dữ liệu và tài khoản</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
