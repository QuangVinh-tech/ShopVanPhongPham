@page
@model RegisterModel
@{
    ViewData["Title"] = "Đăng ký";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="py-5" style="min-height:80vh; background:#f8f9fa;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">

                <div class="card shadow border-0 rounded-4 p-4">
                    <!-- Header -->
                    <div class="text-center mb-4">
                        <i class="bi bi-person-plus-fill text-warning" style="font-size:3rem;"></i>
                        <h3 class="fw-bold mt-2">Tạo tài khoản</h3>
                        <p class="text-muted small">Đăng ký để mua sắm tại VPP Shop</p>
                    </div>

                    <!-- Form -->
                    <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email"
                                   class="form-control rounded-3"
                                   autocomplete="username"
                                   aria-required="true"
                                   placeholder="email@example.com" />
                            <label asp-for="Input.Email">
                                <i class="bi bi-envelope me-1"></i>Email
                            </label>
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Password"
                                   class="form-control rounded-3"
                                   autocomplete="new-password"
                                   aria-required="true"
                                   placeholder="Mật khẩu" />
                            <label asp-for="Input.Password">
                                <i class="bi bi-lock me-1"></i>Mật khẩu
                            </label>
                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-4">
                            <input asp-for="Input.ConfirmPassword"
                                   class="form-control rounded-3"
                                   autocomplete="new-password"
                                   aria-required="true"
                                   placeholder="Xác nhận mật khẩu" />
                            <label asp-for="Input.ConfirmPassword">
                                <i class="bi bi-lock-fill me-1"></i>Xác nhận mật khẩu
                            </label>
<span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <button id="registerSubmit" type="submit"
                                class="w-100 btn btn-warning fw-bold py-2 rounded-3">
                            <i class="bi bi-person-check me-2"></i>Đăng ký
                        </button>
                    </form>

                    <hr class="my-4" />

                    <div class="text-center small">
                        <p class="mb-0">
                            Đã có tài khoản?
                            <a asp-page="./Login" class="text-warning fw-semibold text-decoration-none">
                                Đăng nhập
                            </a>
                        </p>
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}