@page
@model LoginModel
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="py-5" style="min-height:80vh; background:#f8f9fa;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-md-5 col-lg-4">

                <div class="card shadow border-0 rounded-4 p-4">
                    <!-- Header -->
                    <div class="text-center mb-4">
                        <i class="bi bi-person-circle text-warning" style="font-size:3rem;"></i>
                        <h3 class="fw-bold mt-2">Đăng nhập</h3>
                        <p class="text-muted small">Chào mừng bạn quay lại VPP Shop</p>
                    </div>

                    <!-- Form -->
                    <form id="account" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email"
                                   class="form-control rounded-3"
                                   autocomplete="username"
                                   aria-required="true"
                                   placeholder="email@example.com" />
                            <label asp-for="Input.Email">
                                <i class="bi bi-envelope me-1"></i>Email
                            </label>
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Password"
                                   class="form-control rounded-3"
                                   autocomplete="current-password"
                                   aria-required="true"
                                   placeholder="Mật khẩu" />
                            <label asp-for="Input.Password">
                                <i class="bi bi-lock me-1"></i>Mật khẩu
                            </label>
                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div class="form-check">
                                <input class="form-check-input" asp-for="Input.RememberMe" />
                                <label class="form-check-label small" asp-for="Input.RememberMe">
                                    Ghi nhớ đăng nhập
                                </label>
                            </div>
                        </div>

                        <button id="login-submit" type="submit"
                                class="w-100 btn btn-warning fw-bold py-2 rounded-3">
<i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập
                        </button>
                    </form>

                    <hr class="my-4" />

                    <div class="text-center small">
                        <p class="mb-1">
                            Chưa có tài khoản?
                            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl"
                               class="text-warning fw-semibold text-decoration-none">
                                Đăng ký ngay
                            </a>
                        </p>
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}