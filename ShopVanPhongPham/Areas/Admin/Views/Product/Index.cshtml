@model List<ShopVanPhongPham.Models.Product>
@{
    ViewData["Title"] = "Quản lý sản phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold mb-0">📦 Quản lý sản phẩm</h2>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-circle me-1"></i>Thêm sản phẩm
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Ảnh</th>
                    <th>Tên sản phẩm</th>
                    <th>Danh mục</th>
                    <th class="text-end">Giá</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.Count; i++)
                {
                    var p = Model[i];
                    <tr>
                        <td>@(i + 1)</td>
                        <td>
                            <img src="@p.ImageUrl" style="width:50px;height:50px;object-fit:cover"
                                 class="rounded" />
                        </td>
                        <td>@p.Name</td>
                        <td><span class="badge bg-secondary">@p.Category</span></td>
                        <td class="text-end text-danger fw-bold">
                            @p.Price.ToString("N0") đ
                        </td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@p.Id"
                               class="btn btn-sm btn-warning me-1">
                                <i class="bi bi-pencil"></i> Sửa
                            </a>
                            <a asp-action="Delete" asp-route-id="@p.Id"
                               class="btn btn-sm btn-danger">
                                <i class="bi bi-trash"></i> Xóa
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>