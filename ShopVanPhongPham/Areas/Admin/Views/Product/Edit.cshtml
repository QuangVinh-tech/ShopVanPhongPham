@model ShopVanPhongPham.Models.Product
@{
    ViewData["Title"] = "Sửa sản phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary me-3"> Quay lại</a>
    <h2 class="fw-bold mb-0">✏️ Sửa sản phẩm</h2>
</div>

<div class="card shadow-sm" style="max-width:600px">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div class="mb-3">
                <label class="form-label fw-semibold">Tên sản phẩm</label>
                <input asp-for="Name" class="form-control" required />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Mô tả</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Giá (đ)</label>
                <input asp-for="Price" class="form-control" type="number" required />
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Danh mục</label>
                <select asp-for="Category" class="form-select">
                    <option value="But">Bút</option>
                    <option value="So">Sổ/Tập</option>
                    <option value="DungCu">Dụng cụ</option>
                    <option value="Giay">Giấy</option>
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">URL ảnh</label>
                <input asp-for="ImageUrl" class="form-control" />
            </div>
            <button type="submit" class="btn btn-warning w-100">
                Lưu thay đổi
            </button>
        </form>
    </div>
</div>