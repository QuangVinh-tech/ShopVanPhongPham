@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";

    // Tạo URL một lần, dùng lại trong onclick
    var urlProduct = Url.Action("Index", "Product", new { area = "Admin" });
    var urlOrder = Url.Action("Index", "Order", new { area = "Admin" });
    var urlUser = Url.Action("Index", "User", new { area = "Admin" });
    var urlPending = Url.Action("Index", "Order", new { area = "Admin", status = "Chờ xử lý" });
    var urlShip = Url.Action("Index", "Order", new { area = "Admin", status = "Đang giao" });
    var urlDone = Url.Action("Index", "Order", new { area = "Admin", status = "Đã giao" });
    var urlCancel = Url.Action("Index", "Order", new { area = "Admin", status = "Đã hủy" });
}

<h2 class="fw-bold mb-4">Dashboard</h2>

@* 4 thẻ thống kê — dùng onclick="location.href" để chắc chắn navigate *@
<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card stat-card stat-card-products"
             onclick="location.href='@urlProduct'">
            <div class="card-body d-flex align-items-center gap-3 py-4">
                <i class="bi bi-box-seam fs-1"></i>
                <div>
                    <div class="small opacity-75">Sản phẩm</div>
                    <div class="display-6 fw-bold">@ViewBag.TotalProducts</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card stat-card-orders"
             onclick="location.href='@urlOrder'">
            <div class="card-body d-flex align-items-center gap-3 py-4">
                <i class="bi bi-receipt fs-1"></i>
                <div>
                    <div class="small opacity-75">Đơn hàng</div>
                    <div class="display-6 fw-bold">@ViewBag.TotalOrders</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card stat-card-users"
             onclick="location.href='@urlUser'">
            <div class="card-body d-flex align-items-center gap-3 py-4">
                <i class="bi bi-people fs-1"></i>
                <div>
                    <div class="small opacity-75">Người dùng</div>
                    <div class="display-6 fw-bold">@ViewBag.TotalUsers</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card stat-card stat-card-revenue">
            <div class="card-body d-flex align-items-center gap-3 py-4">
                <i class="bi bi-cash-stack fs-1"></i>
                <div>
                    <div class="small opacity-75">Doanh thu</div>
                    <div class="fs-4 fw-bold">@(((decimal)ViewBag.TotalRevenue).ToString("N0")) ₫</div>
                </div>
            </div>
        </div>
    </div>
</div>

@* Trạng thái đơn hàng — mỗi dòng click được *@
<div class="card shadow-sm">
    <div class="card-header fw-bold bg-light">Đơn hàng theo trạng thái</div>
    <div class="card-body p-0">
        <div class="list-group list-group-flush">
            <div class="list-group-item status-row d-flex justify-content-between align-items-center px-4 py-3"
                 onclick="location.href='@urlPending'">
                <span>Chờ xử lý</span>
                <span class="badge bg-warning text-dark fs-6 px-3">@ViewBag.PendingOrders</span>
            </div>
            <div class="list-group-item status-row d-flex justify-content-between align-items-center px-4 py-3"
                 onclick="location.href='@urlShip'">
                <span>Đang giao</span>
                <span class="badge bg-info text-dark fs-6 px-3">@ViewBag.ShippingOrders</span>
            </div>
            <div class="list-group-item status-row d-flex justify-content-between align-items-center px-4 py-3"
                 onclick="location.href='@urlDone'">
                <span>Đã giao</span>
                <span class="badge bg-success fs-6 px-3">@ViewBag.DoneOrders</span>
            </div>
            <div class="list-group-item status-row d-flex justify-content-between align-items-center px-4 py-3"
                 onclick="location.href='@urlCancel'">
                <span>Đã hủy</span>
                <span class="badge bg-danger fs-6 px-3">@ViewBag.CancelledOrders</span>
            </div>
        </div>
    </div>
</div>
