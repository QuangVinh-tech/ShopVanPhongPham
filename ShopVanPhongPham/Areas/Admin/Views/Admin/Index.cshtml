@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h2 class="fw-bold mb-4">📊 Dashboard</h2>

@* Thẻ thống kê chính *@
<div class="row g-4 mb-5">
    <div class="col-md-3">
        <div class="card text-white bg-primary shadow h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="bi bi-box-seam fs-1"></i>
                <div>
                    <div class="small opacity-75">Sản phẩm</div>
                    <div class="display-6 fw-bold">@ViewBag.TotalProducts</div>
                </div>
            </div>
            <div class="card-footer border-0" style="background:rgba(0,0,0,.15)">
                <a asp-area="Admin" asp-controller="Product" asp-action="Index"
                   class="text-white text-decoration-none small">Quản lý →</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success shadow h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="bi bi-receipt fs-1"></i>
                <div>
                    <div class="small opacity-75">Đơn hàng</div>
                    <div class="display-6 fw-bold">@ViewBag.TotalOrders</div>
                </div>
            </div>
            <div class="card-footer border-0" style="background:rgba(0,0,0,.15)">
                <a asp-area="Admin" asp-controller="Order" asp-action="Index"
                   class="text-white text-decoration-none small">Xem tất cả →</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-dark bg-warning shadow h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="bi bi-people fs-1"></i>
                <div>
                    <div class="small opacity-75">Người dùng</div>
                    <div class="display-6 fw-bold">@ViewBag.TotalUsers</div>
                </div>
            </div>
            <div class="card-footer border-0" style="background:rgba(0,0,0,.1)">
                <a asp-area="Admin" asp-controller="User" asp-action="Index"
                   class="text-dark text-decoration-none small">Quản lý →</a>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-danger shadow h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="bi bi-cash-stack fs-1"></i>
                <div>
                    <div class="small opacity-75">Doanh thu</div>
                    <div class="fs-4 fw-bold">@(((decimal)ViewBag.TotalRevenue).ToString("N0")) ₫</div>
                </div>
            </div>
            <div class="card-footer border-0" style="background:rgba(0,0,0,.15)">
                <span class="text-white small opacity-75">Tổng cộng</span>
            </div>
        </div>
    </div>
</div>

@* Trạng thái đơn hàng + Truy cập nhanh *@
<div class="row g-4">
    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-header fw-bold bg-light">📦 Đơn hàng theo trạng thái</div>
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span>⏳ Chờ xử lý</span>
                    <span class="badge bg-warning text-dark fs-6 px-3">@ViewBag.PendingOrders</span>
                </div>
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span>🚚 Đang giao</span>
                    <span class="badge bg-info text-dark fs-6 px-3">@ViewBag.ShippingOrders</span>
                </div>
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span>✅ Đã giao</span>
                    <span class="badge bg-success fs-6 px-3">@ViewBag.DoneOrders</span>
                </div>
                <div class="d-flex justify-content-between align-items-center">
                    <span>❌ Đã hủy</span>
                    <span class="badge bg-danger fs-6 px-3">@ViewBag.CancelledOrders</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-header fw-bold bg-light">🔗 Truy cập nhanh</div>
            <div class="card-body d-grid gap-2">
                <a asp-area="Admin" asp-controller="Product" asp-action="Create"
                   class="btn btn-outline-primary">
                    ➕ Thêm sản phẩm mới
                </a>
                <a asp-area="Admin" asp-controller="Order" asp-action="Index"
                   asp-route-status="Chờ xử lý"
                   class="btn btn-outline-warning">
                    ⏳ Xem đơn chờ xử lý (@ViewBag.PendingOrders)
                </a>
                <a asp-area="Admin" asp-controller="User" asp-action="Index"
                   class="btn btn-outline-secondary">
                    👥 Quản lý người dùng
                </a>
            </div>
        </div>
    </div>
</div>
