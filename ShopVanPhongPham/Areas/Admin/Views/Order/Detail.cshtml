@using ShopVanPhongPham.Models
@model Order
@{
    ViewData["Title"] = $"Chi tiết đơn #{Model.Id}";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var status = Model.Status ?? "Chờ xử lý";
    var badgeClass = status switch
    {
        "Đang giao" => "bg-info text-dark",
        "Đã giao" => "bg-success",
        "Đã hủy" => "bg-danger",
        _ => "bg-warning text-dark"
    };
}

<div class="d-flex align-items-center mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary me-3">← Quay lại</a>
    <h2 class="fw-bold mb-0">Chi tiết đơn hàng #@Model.Id</h2>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">
    <div class="col-md-5">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Thông tin khách hàng</h5>
            </div>
            <div class="card-body">
                <table class="table table-borderless mb-0">
                    <tr><th class="w-40">Họ tên</th><td>@Model.FirstName @Model.LastName</td></tr>
                    <tr><th>Email</th><td>@Model.Email</td></tr>
                    <tr><th>SĐT</th><td>@Model.Phone</td></tr>
                    <tr><th>Địa chỉ</th><td>@Model.Address</td></tr>
                    <tr><th>Ngày đặt</th><td>@Model.OrderPlaced.ToString("dd/MM/yyyy HH:mm")</td></tr>
                    <tr>
                        <th>Trạng thái</th>
                        <td><span class="badge @badgeClass">@status</span></td>
                    </tr>
                </table>
            </div>
        </div>
    </div>

    <div class="col-md-7">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-secondary text-white">
                <h5 class="mb-0">Sản phẩm đã đặt</h5>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Sản phẩm</th>
                            <th class="text-center">SL</th>
                            <th class="text-end">Đơn giá</th>
                            <th class="text-end">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var detail in Model.OrderDetails ?? new List<OrderDetail>())
                        {
                            <tr>
                                <td>@detail.Product?.Name</td>
                                <td class="text-center">@detail.Quantity</td>
                                <td class="text-end">@detail.Price.ToString("N0") ₫</td>
                                <td class="text-end">@((detail.Price * detail.Quantity).ToString("N0")) ₫</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-secondary">
                        <tr>
                            <td colspan="3" class="fw-bold text-end">Tổng cộng:</td>
                            <td class="fw-bold text-danger text-end fs-5">
                                @Model.OrderTotal.ToString("N0") ₫
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>

@* Cập nhật trạng thái từ trang detail *@
<div class="card shadow-sm mt-4" style="max-width:400px">
    <div class="card-header">Cập nhật trạng thái</div>
    <div class="card-body">
        <form asp-action="UpdateStatus" asp-controller="Order" asp-area="Admin" method="post" class="d-flex gap-2">
            @Html.AntiForgeryToken()
            <input type="hidden" name="orderId" value="@Model.Id" />
            <input type="hidden" name="returnId" value="@Model.Id" />
            <select name="status" class="form-select">
                @foreach (var s in new[] { "Chờ xử lý", "Đang giao", "Đã giao", "Đã hủy" })
                {
                    if (s == status)
                    {
                        <option value="@s" selected>@s</option>
                    }
                    else
                    {
                        <option value="@s">@s</option>
                    }
                }
            </select>
            <button type="submit" class="btn btn-primary text-nowrap">Lưu</button>
        </form>
    </div>
</div>
