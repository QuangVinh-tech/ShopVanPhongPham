
@model IEnumerable<ShopVanPhongPham.Models.ContactMessage>

@{
    ViewData["Title"] = "Phản Hồi Khách Hàng";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">
        <i class="bi bi-envelope me-2 text-primary"></i>Phản Hồi Khách Hàng
        @if (ViewBag.UnreadCount > 0)
        {
            <span class="badge bg-danger ms-2">@ViewBag.UnreadCount chưa đọc</span>
        }
    </h4>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-inbox fs-1"></i>
        <p class="mt-3">Chưa có tin nhắn nào từ khách hàng.</p>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:40px">#</th>
                        <th>Khách hàng</th>
                        <th>Chủ đề</th>
                        <th>Thời gian</th>
                        <th style="width:100px">Trạng thái</th>
                        <th style="width:130px">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var msg in Model)
                    {
                        <tr class="@(!msg.IsRead ? "table-warning fw-semibold" : "")">
                            <td>@msg.Id</td>
                            <td>
                                <div>@msg.FullName</div>
                                <small class="text-muted">@msg.Email</small>
                            </td>
                            <td>@msg.Subject</td>
                            <td>
                                <small>@msg.SentAt.ToString("dd/MM/yyyy HH:mm")</small>
                            </td>
                            <td>
                                @if (msg.IsRead)
                                {
                                    <span class="badge bg-secondary">Đã đọc</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Chưa đọc</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Detail" asp-route-id="@msg.Id"
                                   class="btn btn-sm btn-outline-primary me-1" title="Xem chi tiết">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@msg.Id" method="post"
                                      style="display:inline"
                                      onsubmit="return confirm('Bạn có chắc muốn xóa tin nhắn này?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Xóa">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
