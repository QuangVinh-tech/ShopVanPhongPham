

@model ShopVanPhongPham.Models.ContactMessage

@{
    ViewData["Title"] = "Chi Tiết Phản Hồi";
    Layout = "_AdminLayout";
}

<div class="mb-4">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Quay lại danh sách
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">
    <!-- Thông tin tin nhắn -->
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-envelope-open me-2"></i>@Model.Subject</h5>
                @if (Model.IsRead)
                {
                    <span class="badge bg-secondary">Đã đọc</span>
                }
                else
                {
                    <span class="badge bg-danger">Chưa đọc</span>
                }
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-sm-6">
                        <small class="text-muted d-block">Người gửi</small>
                        <strong>@Model.FullName</strong>
                    </div>
                    <div class="col-sm-6">
                        <small class="text-muted d-block">Email</small>
                        <a href="mailto:@Model.Email">@Model.Email</a>
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(Model.Phone))
                {
                    <div class="mb-3">
                        <small class="text-muted d-block">Số điện thoại</small>
                        <strong>@Model.Phone</strong>
                    </div>
                }
                <div class="mb-3">
                    <small class="text-muted d-block">Thời gian gửi</small>
                    <strong>@Model.SentAt.ToString("HH:mm - dd/MM/yyyy")</strong>
                </div>
                <hr />
                <div>
                    <small class="text-muted d-block mb-2">Nội dung tin nhắn</small>
                    <div class="bg-light p-3 rounded" style="white-space: pre-wrap;">@Model.Message</div>
                </div>
            </div>
        </div>

        <!-- Ghi chú nội bộ của Admin -->
        <div class="card shadow-sm mt-3">
            <div class="card-header">
                <h6 class="mb-0"><i class="bi bi-pencil-square me-2"></i>Ghi Chú Nội Bộ (Admin)</h6>
            </div>
            <div class="card-body">
                <form asp-action="SaveNote" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <textarea name="adminNote" class="form-control" rows="4"
                                  placeholder="Ghi chú xử lý nội bộ, không hiển thị với khách...">@Model.AdminNote</textarea>
                    </div>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save me-1"></i>Lưu ghi chú
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Panel hành động -->
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-header">
                <h6 class="mb-0">Hành Động</h6>
            </div>
            <div class="card-body d-grid gap-2">
                <a href="mailto:@Model.Email?subject=Re: @Model.Subject"
                   class="btn btn-success">
                    <i class="bi bi-reply me-2"></i>Trả lời qua Email
                </a>
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
                      onsubmit="return confirm('Bạn có chắc muốn xóa tin nhắn này?')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-danger w-100">
                        <i class="bi bi-trash me-2"></i>Xóa tin nhắn
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
