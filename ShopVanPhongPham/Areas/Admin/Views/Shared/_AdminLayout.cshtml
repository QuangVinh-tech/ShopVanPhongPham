@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
</head>
<body>
    <div class="d-flex">
        <!-- Sidebar -->
        <div class="bg-dark text-white" style="width:250px; min-height:100vh">
            <div class="p-3 border-bottom border-secondary">
                <h5 class="fw-bold text-warning mb-0">
                    <i class="bi bi-shield-lock me-2"></i>Admin Panel
                </h5>
            </div>
            <ul class="nav flex-column p-2">
                <li class="nav-item">
                    <a class="nav-link text-white" asp-area="Admin" asp-controller="Admin" asp-action="Index">
                        <i class="bi bi-speedometer2 me-2"></i>Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white" asp-area="Admin" asp-controller="Product" asp-action="Index">
                        <i class="bi bi-box me-2"></i>Sản phẩm
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white" asp-area="Admin" asp-controller="Order" asp-action="Index">
                        <i class="bi bi-receipt me-2"></i>Đơn hàng
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link text-white" asp-area="Admin" asp-controller="User" asp-action="Index">
                        <i class="bi bi-people me-2"></i>Người dùng
                    </a>
                </li>
                <li class="nav-item mt-3">
                    <a class="nav-link text-danger" asp-controller="Home" asp-action="Index" asp-area="">
                        <i class="bi bi-arrow-left me-2"></i>Về trang chủ
                    </a>
                </li>
            </ul>
        </div>

        <!-- Main content -->
        <div class="flex-grow-1 p-4">
            @RenderBody()
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>