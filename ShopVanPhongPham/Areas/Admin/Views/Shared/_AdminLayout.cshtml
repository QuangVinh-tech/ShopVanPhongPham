@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();

    bool IsActive(string controller) =>
        string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin | VPP Shop</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body>
    <div class="d-flex admin-wrapper">
        <!-- Sidebar -->
        <div class="admin-sidebar d-flex flex-column">
            <div class="sidebar-brand">
                <h5 class="fw-bold">
                    <i class="bi bi-pencil-square me-2"></i>VPP Shop
                </h5>
                <small>Admin Panel</small>
            </div>
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link @(IsActive("Admin") ? "active" : "")"
                       asp-area="Admin" asp-controller="Admin" asp-action="Index">
                        <i class="bi bi-speedometer2 me-2"></i>Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(IsActive("Product") ? "active" : "")"
                       asp-area="Admin" asp-controller="Product" asp-action="Index">
                        <i class="bi bi-box me-2"></i>Sản phẩm
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(IsActive("Order") ? "active" : "")"
                       asp-area="Admin" asp-controller="Order" asp-action="Index">
                        <i class="bi bi-receipt me-2"></i>Đơn hàng
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(IsActive("Contact") ? "active" : "")"
                       asp-area="Admin" asp-controller="Contact" asp-action="Index">
                        <i class="bi bi-envelope me-2"></i>Phản hồi
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(IsActive("User") ? "active" : "")"
                       asp-area="Admin" asp-controller="User" asp-action="Index">
                        <i class="bi bi-people me-2"></i>Người dùng
                    </a>
                </li>
                <hr />
                <li class="nav-item">
                    <a class="nav-link text-back" asp-controller="Home" asp-action="Index" asp-area="">
                        <i class="bi bi-arrow-left-circle me-2"></i>Về trang chủ
                    </a>
                </li>
            </ul>
        </div>

        <!-- Main content -->
        <div class="d-flex flex-column flex-grow-1" style="min-width:0">
            <div class="admin-topbar d-flex justify-content-between align-items-center">
                <h4>@ViewData["Title"]</h4>
                <div class="d-flex align-items-center gap-3">
                    <span class="badge badge-role rounded-pill px-3 py-2">
                        <i class="bi bi-shield-lock-fill me-1"></i>@(User.Identity?.Name ?? "Admin")
                    </span>
                </div>
            </div>
            <div class="admin-content">
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
