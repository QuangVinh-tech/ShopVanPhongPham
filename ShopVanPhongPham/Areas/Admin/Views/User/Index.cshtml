@using Microsoft.AspNetCore.Identity
@model List<IdentityUser>
@{
    ViewData["Title"] = "Quản lý người dùng";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var userRoles = ViewBag.UserRoles as Dictionary<string, IList<string>>;
}

<h2 class="fw-bold mb-4">👥 Quản lý người dùng</h2>

@if (ViewBag.Success != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @ViewBag.Success
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (ViewBag.Error != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @ViewBag.Error
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th style="width:40px">#</th>
                    <th>Email</th>
                    <th>Role hiện tại</th>
                    <th style="width:260px">Gán role</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.Count; i++)
                {
                    var user = Model[i];
                    var roles = userRoles![user.Id];
                    var cur = roles.FirstOrDefault() ?? "";
                    <tr>
                        <td class="text-muted">@(i + 1)</td>
                        <td>
                            <div class="fw-semibold">@user.Email</div>
                            <div class="text-muted small">@user.UserName</div>
                        </td>
                        <td>
                            @if (roles.Any())
                            {
                                foreach (var r in roles)
                                {
                                    <span class="badge @(r == "Admin" ? "bg-danger" : "bg-primary") fs-6">
                                        @r
                                    </span>
                                }
                            }
                            else
                            {
                                <span class="badge bg-secondary">Chưa có</span>
                            }
                        </td>
                        <td>
                            @* ValidateAntiForgeryToken: PHẢI có @Html.AntiForgeryToken() *@
                            <form asp-action="AssignRole" method="post"
                                  class="d-flex gap-2 align-items-center">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="userId" value="@user.Id" />
                                <select name="role" class="form-select form-select-sm">
                                    <option value="Admin" selected="@(cur == "Admin" ? "selected" : null)">Admin</option>
                                    <option value="User" selected="@(cur == "User" ? "selected" : null)">User</option>
                                </select>
                                <button type="submit" class="btn btn-sm btn-warning text-nowrap">
                                    Lưu
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
