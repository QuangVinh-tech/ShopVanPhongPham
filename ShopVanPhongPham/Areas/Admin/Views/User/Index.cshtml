@using Microsoft.AspNetCore.Identity
@model List<IdentityUser>
@{
    ViewData["Title"] = "Quản lý người dùng";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var userRoles = ViewBag.UserRoles as Dictionary<string, IList<string>>;
}

<h2 class="fw-bold mb-4">👥 Quản lý người dùng</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Email</th>
                    <th>Role hiện tại</th>
                    <th>Gán role</th>
                </tr>
            </thead>
            <tbody>
                @for (int i = 0; i < Model.Count; i++)
                {
                    var user = Model[i];
                    var roles = userRoles![user.Id];
                    <tr>
                        <td>@(i + 1)</td>
                        <td>@user.Email</td>
                        <td>
                            @if (roles.Any())
                            {
                                foreach (var r in roles)
                                {
                                    <span class="badge @(r == "Admin" ? "bg-danger" : "bg-primary")">
                                        @r
                                    </span>
                                }
                            }
                            else
                            {
                                <span class="badge bg-secondary">Chưa có</span>
                            }
                        </td>
                        <td>
                            <form asp-action="AssignRole" method="post" class="d-flex gap-2">
                                <input type="hidden" name="userId" value="@user.Id" />
                                <select name="role" class="form-select form-select-sm w-auto">
                                    <option value="Admin">Admin</option>
                                    <option value="User">User</option>
                                </select>
                                <button type="submit" class="btn btn-sm btn-warning">
                                    Gán role
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>