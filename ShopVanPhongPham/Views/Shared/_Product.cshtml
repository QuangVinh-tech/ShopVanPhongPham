@model ShopVanPhongPham.Models.Product

<div class="card" style="width: 18rem; margin: 10px;">
    <img src="@Model.ImageUrl" class="card-img-top" alt="@Model.Name">
    <div class="card-body">
        <h5 class="card-title">@Model.Name</h5>
        <p class="card-text">@Model.Price.ToString("N0") VNĐ</p>
        <a href="/Product/Detail/@Model.Id" class="btn btn-primary">Xem chi tiết</a>
    </div>
</div>