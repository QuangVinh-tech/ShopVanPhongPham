@model ShopVanPhongPham.Models.Product

@{
    ViewData["Title"] = Model.Name;
}

<section class="product-detail py-5">
    <div class="container">
        <nav aria-label="breadcrumb" class="mb-3">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Trang chủ</a></li>
                <li class="breadcrumb-item"><a href="/Product/Shop">Cửa hàng</a></li>
                <li class="breadcrumb-item active">@Model.Name</li>
            </ol>
        </nav>

        <div class="row">
            <!-- Ảnh sản phẩm -->
            <div class="col-md-5">
                <img src="@Model.ImageUrl"
                     alt="@Model.Name"
                     class="img-fluid rounded shadow"
                     style="width:100%; object-fit:cover;" />
            </div>

            <!-- Thông tin sản phẩm -->
            <div class="col-md-7">
                <h2 class="product-title">@Model.Name</h2>

                <div class="price-box my-3">
                    <span class="fs-3 fw-bold text-danger">
                        @Model.Price.ToString("N0") ₫
                    </span>
                </div>

                <p class="product-description text-muted">@Model.Description</p>

                <hr />

                <div class="d-flex gap-2 mt-3">
                    <!-- Thêm vào giỏ -->
                    <a asp-controller="ShoppingCart"
                       asp-action="AddToCart"
                       asp-route-id="@Model.Id"
                       class="btn btn-primary btn-lg">
                        🛒 Thêm vào giỏ hàng
                    </a>

                    <!-- Quay lại -->
                    <a asp-controller="Product"
                       asp-action="Shop"
                       class="btn btn-outline-secondary btn-lg">
                        ← Tiếp tục mua
                    </a>
                </div>

                <!-- Chính sách -->
                <div class="policy-box mt-4 p-3 bg-light rounded">
                    <small>
                        ✅ Hàng chính hãng 100% &nbsp;|&nbsp;
                        🚚 Giao hàng 1–3 ngày &nbsp;|&nbsp;
                        🔄 Đổi trả trong 7 ngày
                    </small>
                </div>
            </div>
        </div>
    </div>
</section>