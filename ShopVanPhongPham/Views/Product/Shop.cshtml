@model IEnumerable<ShopVanPhongPham.Models.Product>

@{
    ViewData["Title"] = "Cửa Hàng";
}

<section class="shop-page py-5">
    <div class="container">
        <h2 class="mb-4">🛒 Tất Cả Sản Phẩm</h2>

        <!-- Thanh lọc / tìm kiếm server-side -->
        <form asp-action="Shop" method="get" class="row g-2 mb-4">
            <div class="col-md-6">
                <input name="search" value="@ViewBag.Search"
                       type="text" class="form-control"
                       placeholder="🔍 Tìm sản phẩm..." />
            </div>
            <div class="col-md-4">
                <select name="category" class="form-select">
                    <option value="">-- Tất cả danh mục --</option>
                    @foreach (var cat in ViewBag.Categories as List<string> ?? new List<string>())
                    {
                        @if (ViewBag.Category == cat)
                        {
                            <option value="@cat" selected>@cat</option>
                        }
                        else
                        {
                            <option value="@cat">@cat</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">
                    Lọc
                </button>
            </div>
        </form>

        <!-- Hiển thị kết quả -->
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <div style="font-size:3rem">😕</div>
                <h5 class="text-muted mt-3">Không tìm thấy sản phẩm nào</h5>
                <a asp-action="Shop" class="btn btn-outline-primary mt-3">
                    Xem tất cả sản phẩm
                </a>
            </div>
        }
        else
        {
            <div class="row" id="productGrid">
                @foreach (var product in Model)
                {
                    <div class="col-md-3 mb-4 product-item">
                        @await Html.PartialAsync("_Product", product)
                    </div>
                }
            </div>
        }
    </div>
</section>