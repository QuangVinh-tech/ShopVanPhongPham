@using ShopVanPhongPham.Models
@model List<ShoppingCartItem>
@{
    ViewData["Title"] = "Thanh toán";
    var total = Model.Sum(i => i.Product!.Price * i.Quantity);
}

<div class="container py-4">
    <h2 class="fw-bold mb-4">Xác nhận & Thanh toán</h2>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger">Vui lòng điền đầy đủ thông tin.</div>
    }

    <div class="row g-4">

        <div class="col-lg-5">
            <div class="card shadow-sm">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0">Giỏ hàng của bạn</h5>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Sản phẩm</th>
                                <th class="text-center">SL</th>
                                <th class="text-end">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Product!.Name</td>
                                    <td class="text-center">@item.Quantity</td>
                                    <td class="text-end">
                                        @((item.Product.Price * item.Quantity).ToString("N0")) đ
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-secondary">
                            <tr>
                                <td colspan="2" class="fw-bold">Tổng cộng</td>
                                <td class="text-end fw-bold text-danger fs-5">
                                    @Model.Sum(i => i.Product!.Price * i.Quantity).ToString("N0") đ
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Thông tin giao hàng</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Checkout" method="post">
                        @Html.AntiForgeryToken()

                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">
                                    Họ <span class="text-danger">*</span>
                                </label>
                                <input name="firstName" class="form-control"
                                       placeholder="Nguyễn" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">
                                    Tên <span class="text-danger">*</span>
                                </label>
                                <input name="lastName" class="form-control"
                                       placeholder="Văn A" required />
                            </div>

                            <div class="col-12">
                                <label class="form-label fw-semibold">
                                    Số điện thoại <span class="text-danger">*</span>
                                </label>
                                <input name="phone" class="form-control"
                                       placeholder="0901234567" required />
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-semibold">
                                    Địa chỉ giao hàng <span class="text-danger">*</span>
                                </label>
                                <textarea name="address" class="form-control" rows="3"
                                          placeholder="Số nhà, đường, phường, quận, tỉnh/thành"
                                          required></textarea>
                            </div>

                            
                            <div class="col-12">
                                <label class="form-label fw-semibold">Phương thức thanh toán</label>

                                <div class="form-check border rounded-3 p-3 mb-2">
                                    <input class="form-check-input" type="radio"
                                           name="paymentMethod" value="COD" id="cod" checked>
                                    <label class="form-check-label fw-semibold" for="cod">
                                        Thanh toán khi nhận hàng (COD)
                                    </label>
                                </div>

                                <div class="form-check border rounded-3 p-3">
                                    <input class="form-check-input" type="radio"
                                           name="paymentMethod" value="QR" id="qr">
                                    <label class="form-check-label fw-semibold" for="qr">
                                        Chuyển khoản QR (VietQR)
                                    </label>
                                </div>
                            </div>

                          
                            <div class="col-12">
                                <div id="qrPreview" class="text-center border rounded-3 p-3 d-none">
                                    <img src="@ViewBag.QrPreviewUrl" alt="VietQR"
                                         style="max-width:240px;" class="mb-2" />
                                    <p class="text-muted small mb-0">
                                        Quét mã để chuyển khoản. Mã đơn hàng chính xác sẽ hiện
                                        ở trang xác nhận sau khi bạn bấm "Đặt hàng ngay".
                                    </p>
                                </div>
                            </div>
                            
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-success btn-lg">
                                Đặt hàng ngay
                            </button>
                            <a asp-controller="ShoppingCart" asp-action="Index"
                               class="btn btn-outline-secondary">
                                ← Quay lại giỏ hàng
                            </a>
                        </div>

                    </form>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const radios = document.querySelectorAll('input[name="paymentMethod"]');
            const qrBox = document.getElementById('qrPreview');

            radios.forEach(radio => {
                radio.addEventListener('change', function () {
                    qrBox.classList.toggle('d-none', this.value !== 'QR');
                });
            });
        });
    </script>
}