@using ShopVanPhongPham.Models
@model List<Order>
@{
    ViewData["Title"] = "Đơn hàng của tôi";
}

<div class="container py-4">
    <h2 class="fw-bold mb-4">📦 Đơn hàng của tôi</h2>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div style="font-size:3rem">🛒</div>
            <h5 class="text-muted mt-3">Bạn chưa có đơn hàng nào</h5>
            <a asp-controller="Product" asp-action="Shop"
               class="btn btn-primary mt-3">
                🛍️ Mua sắm ngay
            </a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Mã đơn</th>
                        <th>Ngày đặt</th>
                        <th>Người nhận</th>
                        <th>Địa chỉ</th>
                        <th class="text-end">Tổng tiền</th>
                        <th class="text-center">Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td><strong>#@order.Id</strong></td>
                            <td>@order.OrderPlaced.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@order.FirstName @order.LastName</td>
                            <td>@order.Address</td>
                            <td class="text-end fw-bold text-danger">
                                @order.OrderTotal.ToString("N0") ₫
                            </td>
                            <td class="text-center">
                                <span class="badge bg-warning text-dark">
                                    @(order.Status ?? "Chờ xử lý")
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <a asp-controller="Product" asp-action="Shop"
       class="btn btn-outline-primary mt-3">
        ← Tiếp tục mua sắm
    </a>
</div>